#!/bin/sh
# initramfs-tools hook -- include the nbdboot driver's binaries +
# kernel modules in the initramfs.
#
# initramfs-tools runs every executable under
# ``/etc/initramfs-tools/hooks/`` during ``update-initramfs``. This
# hook's job is to populate the initramfs's filesystem with:
#
#   * ``nbd-client``         -- connect to the nbdmux daemon
#   * ``busybox`` (static)   -- shell + utilities for /init
#   * ``nbd``  kernel module -- exposes /dev/nbdN
#   * ``overlay`` module     -- overlayfs for the tmpfs-over-NBD root
#   * ``ext4`` / ``xfs`` modules -- mount the image's root partition
#
# The ``copy_exec`` + ``manual_add_modules`` helpers come from
# ``/usr/share/initramfs-tools/hook-functions``; they handle library
# resolution + cross-arch corner cases.

set -e

# initramfs-tools sources its boilerplate (PREREQS handling + the
# copy_exec / manual_add_modules helpers) via this magic preamble.
PREREQ=""
prereqs() { echo "$PREREQ"; }
case "${1:-}" in
    prereqs) prereqs; exit 0 ;;
esac
# shellcheck disable=SC1091
. /usr/share/initramfs-tools/hook-functions

# Userland binaries. ``busybox`` ships as ``/usr/bin/busybox`` (or
# ``/bin/busybox`` on older distros); copy_exec finds it via PATH.
copy_exec /usr/sbin/nbd-client /sbin
copy_exec /usr/bin/busybox /bin

# Kernel modules. ``nbd`` is the block device; ``overlay`` is the
# write-aside filesystem; the rest are the FS drivers the target
# image's root partition might use (image-builder typically lands
# on ext4; xfs + btrfs cover the common alternatives).
manual_add_modules nbd
manual_add_modules overlay
manual_add_modules ext4
manual_add_modules xfs
manual_add_modules btrfs

# NIC drivers. The netboot-pc live-boot chain uses
# ``ip=dhcp fetch=<squashfs URL>`` on the kernel cmdline: the initrd
# DHCPs the interface + pulls the squashfs over HTTP BEFORE any
# userspace runs. Without the NIC driver in the initrd, DHCP fails
# and ``fetch=`` never fires (visible on the pixie access log as
# repeated ``GET /pxe-bootstrap.ipxe`` from the same MAC but no
# ``GET .../squashfs`` in between). Force the four drivers pixie's
# target hardware uses; ``manual_add_modules`` also pulls each
# module's declared firmware (rtl_nic/*.fw comes from
# firmware-realtek in the chroot).
#
# * ``r8125`` -- the awesometic realtek-r8125-dkms out-of-tree
#   driver installed by the sibling ``0600-pixie-r8125-dkms.hook.chroot``
#   for RTL8125 / RTL8125B / RTL8126 2.5GbE. Without this line,
#   ``dkms install`` lands ``r8125.ko.xz`` under
#   ``/lib/modules/$KVER/updates/`` but nothing pulls it into the
#   shipped initrd -- observed on matx-bmc (RTL8125), where the
#   live-env kernel booted, initrd hung silently at driver-probe
#   time, and no ``fetch=`` ever hit pixie.
# * ``r8169`` -- in-tree fallback for the same family + RTL8168 +
#   older Realtek 1GbE. Loaded via softdep when r8125 fails
#   (Secure-Boot lockdown rejects the unsigned DKMS module).
# * ``igb`` + ``e1000e`` -- Intel 1GbE, common on the same class
#   of mini-PC + lab motherboards.
#
# ``manual_add_modules`` silently no-ops for a module that is not
# installed, so the arm64 build-rpi variant (r8125 skipped per
# 0600's arch guard, no linux-headers-arm64 in that chroot) still
# succeeds.
manual_add_modules r8125
manual_add_modules r8169
manual_add_modules igb
manual_add_modules e1000e
